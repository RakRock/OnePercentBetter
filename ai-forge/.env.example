# ── AI Forge environment (copy to .env) ──

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (SQLite default for local venv; use Postgres in production)
DATABASE_URL=sqlite+aiosqlite:///../data/aiforge.db

# Redis / Celery (Phase 2+)
REDIS_URL=redis://localhost:6379/0

# Vector DB (Phase 2+)
QDRANT_URL=http://localhost:6333

# AI providers (Claude primary)
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Optional alternates (LiteLLM abstraction)
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="AI Forge"

# OnePercent Streamlit bridge
AIFORGE_PUBLIC_URL=http://localhost:3000
